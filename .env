PORT=8000
HOST=0.0.0.0
ENV=development

# Database Settings (PostgreSQL)
DATABASE_URL=postgresql://postgres:post123@localhost:5432/ticket_db

# Redis Configuration (For Concurrency Locks, TTL Holds, & Queues)
REDIS_URL=redis://localhost:6379/0

# Security Settings
JWT_SECRET=super_secret_jwt_signing_key_change_me_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Email Integration (SMTP Free Tier Example)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=noreply@ticketbookingsystem.com

# Configuration Parameter
SEAT_HOLD_TTL_SECONDS=600
WAITLIST_OFFER_TTL_SECONDS=300